# =====================================================
# Bravus Bank — variáveis de ambiente (exemplo)
# Copie este arquivo para `.env` e ajuste os valores.
# Ou rode `./dev-up.sh` que cria automaticamente.
# =====================================================

# --- Banco de Dados (PostgreSQL) ---
DB_NAME=bravus
DB_USER=bravus
DB_PASSWORD=bravus

# --- JWT (OBRIGATÓRIO!) ---
# Gere um segredo forte com: openssl rand -base64 64 | tr -d '\n/'
# Mínimo 32 bytes (recomendado 64). NUNCA use este placeholder em produção.
JWT_SECRET=DEV_ONLY_change_me_AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# --- CORS ---
# URL do frontend (Vite roda em 5173 por padrão)
CORS_ORIGIN=http://localhost:5173

# --- Protecao de midia biometrica ---
# Chave AES-256 em Base64. Gere com: openssl rand -base64 32
# Obrigatoria em producao. Nunca reutilize JWT_SECRET nem versione a chave real.
BRAVUS_BIOMETRIC_KEY=
BRAVUS_PASSWORD_RESET_GLOBAL_LIMIT=300

# --- Stripe (opcional em dev) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_FEE_PERCENT=10
STRIPE_SUCCESS_URL=http://localhost:5173/payment/success
STRIPE_CANCEL_URL=http://localhost:5173/payment/cancel
STRIPE_CURRENCY=brl
STRIPE_CONNECT=false

# --- Analise CPF/CNPJ ---
# INTERNAL = provedor proprio Bravus, sem chamada externa por padrao.
# BRASILAPI = usa BRAVUS_CNPJ_API_URL apenas para CNPJ; CPF continua interno se
# BRAVUS_CPF_API_URL nao estiver configurado.
# EXTERNAL = usa BRAVUS_CNPJ_API_URL/BRAVUS_CPF_API_URL quando configurados.
BRAVUS_DOCUMENT_ANALYSIS_MODE=INTERNAL
BRAVUS_CNPJ_API_URL=

# CPF oficial exige acesso contratado/licenciado a uma fonte autorizada.
# Use {document} se o seu endpoint proprio exigir o CPF no meio da URL.
BRAVUS_CPF_API_URL=
BRAVUS_CPF_API_TOKEN=

# --- Transferencia bancaria externa real ---
# Aponte para o seu gateway bancario proprio/licenciado para Pix/TED.
# Sem isso, o sistema bloqueia o envio externo em vez de simular dinheiro real.
BRAVUS_BANKING_PROVIDER_NAME=BRAVUS_GATEWAY
BRAVUS_BANKING_PROVIDER_URL=
BRAVUS_BANKING_PROVIDER_TOKEN=
